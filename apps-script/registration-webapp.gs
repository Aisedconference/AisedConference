function appendSheetRow(sheet, values) {
  sheet.appendRow(values.map(safeSheetValue));
}

function safeSheetValue(value) {
  if (value === null || value === undefined) return '';
  if (typeof value !== 'string') return value;
  if (/^[=+\-@]/.test(value)) return `'${value}`;
  return value;
}

function attachmentUrlByField(record, fieldName) {
  if (!record.savedAttachments || !record.savedAttachments.length) return '';
  return record.savedAttachments
    .filter((attachment) => attachment.field === fieldName)
    .map((attachment) => attachment.url)
    .join('\n');
}

