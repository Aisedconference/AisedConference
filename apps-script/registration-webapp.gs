    record.hrdClaimableCourse,
    record.participantIdNumber,
    record.department,
    record.companyRegistration,
    record.billingContact,
    record.contactPersonPosition,
    record.billingEmail,
    record.billingPhone,
    record.companyAddress,
    record.referenceNo,
    record.participantNotes,
    record.invitationNote,
