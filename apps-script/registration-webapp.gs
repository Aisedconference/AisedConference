const AISED_LETTERHEAD_BACKGROUND = 'data:image/jpeg;base64,';

function doPost(e) {
  try {
    const payload = JSON.parse(e.postData.contents || '{}');
    const record = normaliseRecord(payload);
    const attachments = saveAttachments(record);
    if (attachments.length) {
      record.savedAttachments = attachments;
      record.attachmentName = attachments.map((attachment) => `${attachment.label}: ${attachment.name}`).join(' | ');
      record.attachmentUrl = attachments.map((attachment) => `${attachment.label}: ${attachment.url}`).join('\n');
    }

    appendRegistrationRows(record);
    const pdf = shouldAttachPdf(record) ? createConfirmationPdf(record) : null;
    const emailStatus = sendConfirmationEmail(record, pdf);

    return jsonResponse({
      ok: true,
      reference: record.reference,
      message: 'Registration received.',
      emailStatus
    });
  } catch (error) {
    return jsonResponse({
      ok: false,
      message: error.message || String(error)
    });
  }
}

function normaliseRecord(payload) {
  const category = payload.registration_category || '';
  const subsection = payload.registration_subsection || '';
  const type = payload.registration_type || '';
  const route = getRoute(category);

  return {
    reference: payload.reference || makeReference(),
    submittedAt: payload.submittedAt || new Date().toISOString(),
    source: payload.source || 'AiSED website',
    route,
    category,
    subsection,
    type,
    partnerType: category === 'partners' ? type : '',
    title: payload.title || '',
    name: payload.name || '',
    email: payload.email || '',
    phone: payload.phone || '',
    organisation: payload.organisation || '',
    position: payload.position || '',
    attendanceInterest: payload.attendance_interest || '',
    participantSector: payload.participant_sector || '',
    billingContact: payload.billing_contact || '',
    billingEmail: payload.billing_email || '',
    billingPhone: payload.billing_phone || '',
    companyRegistration: payload.company_registration || '',
    hrdEmployerId: payload.hrd_employer_id || '',
    hrdClaimableCourse: payload.hrd_claimable_course || '',
    participantIdNumber: payload.participant_id_number || '',
    contactPersonPosition: payload.contact_person_position || '',
    companyAddress: payload.company_address || '',
    department: payload.department || '',
    referenceNo: payload.reference_no || '',
    participantNotes: payload.participant_notes || '',
    guestType: payload.guest_type || '',
    invitationNote: payload.invitation_note || '',
    speakerBiography: payload.speaker_biography || '',
    partnershipContact: payload.partnership_contact || '',
    website: payload.website || '',
    partnershipInterest: payload.partnership_interest || '',
    paperTitle: payload.paper_title || '',
    abstract: payload.abstract || '',
    submitToScopus: payload.submit_to_scopus || '',
    scopusPresentationMode: payload.scopus_presentation_mode || '',
    estimatedPayableAmount: payload.estimated_payable_amount || '',
    estimatedFeeBreakdown: payload.estimated_fee_breakdown || '',
    attachments: Array.isArray(payload.attachments) ? payload.attachments : [],
    attachmentName: payload.attachmentName || '',
    attachment: payload.attachment || null,
    attachmentUrl: '',
    savedAttachments: [],
    status: 'New'
  };
}

function getRoute(category) {
  if (category === 'call-papers') return 'Call for Papers';
  if (category === 'participants') return 'Participants';
  if (category === 'invited-guests') return 'Invited Guests';
  if (category === 'partners') return 'Partners';
  return 'Registration';
}

function getFolderId(record) {
  if (record.category === 'call-papers') return AISED.folders.callPapers;
  if (record.category === 'participants') return AISED.folders.participants;
  if (record.category === 'invited-guests') return AISED.folders.invitedGuests;
  if (record.category === 'partners') return AISED.folders.partners;
  return AISED.folders.participants;
}

function saveAttachments(record) {
  const uploadItems = record.attachments.length
    ? record.attachments
    : (record.attachment && record.attachment.data ? [{ ...record.attachment, label: record.attachmentName || 'Attachment' }] : []);

  if (!uploadItems.length) {
    return [];
  }

  const folder = DriveApp.getFolderById(getFolderId(record));

  return uploadItems
    .filter((attachment) => attachment && attachment.data)
    .map((attachment) => {
      const safeLabel = String(attachment.label || attachment.field || 'Attachment').replace(/[^\w.\- ]/g, '_');
      const safeName = String(attachment.name || 'attachment').replace(/[^\w.\- ]/g, '_');
      const bytes = Utilities.base64Decode(attachment.data);
      const blob = Utilities.newBlob(
        bytes,
        attachment.type || 'application/octet-stream',
        `${record.reference} - ${safeLabel} - ${safeName}`
      );
      const file = folder.createFile(blob);
      file.setDescription(`${AISED.conferenceName} registration attachment for ${record.reference}: ${attachment.label || safeName}`);
      return {
        field: attachment.field || '',
        label: attachment.label || attachment.field || 'Attachment',
        name: attachment.name || safeName,
        url: file.getUrl()
      };
    });
}

