function sendConfirmationEmail(record, pdf) {
  if (!record.email) {
    return { sent: false, reason: 'No recipient email address provided.' };
  }

  const subject = getEmailSubject(record);
  const body = getEmailBody(record);
  const sender = getEmailSender(record);
  const options = {
    name: sender.name,
    replyTo: sender.replyTo
  };

  if (pdf) options.attachments = [pdf];

  try {
    const aliases = GmailApp.getAliases();
    if (aliases.indexOf(sender.from) !== -1) {
      GmailApp.sendEmail(record.email, subject, body, {
        ...options,
        from: sender.from
      });
      return { sent: true, from: sender.from };
    }

    MailApp.sendEmail({
      to: record.email,
      subject,
      body,
      name: options.name,
      replyTo: AISED.replyTo,
      attachments: options.attachments
    });
    return {
      sent: true,
      from: 'script account',
      replyTo: sender.replyTo,
      note: `${sender.from} is not configured as a Gmail sender alias.`
    };
  } catch (error) {
    console.error(`Confirmation email failed for ${record.reference}: ${error.message || error}`);
    return {
      sent: false,
      reason: error.message || String(error)
    };
  }
}

function getEmailSender(record) {
  if (record.route === 'Call for Papers') {
    return {
      from: AISED.papersEmailFrom,
      replyTo: AISED.papersReplyTo,
      name: 'AiSED Conference Papers Secretariat'
    };
  }

  return {
    from: AISED.emailFrom,
    replyTo: AISED.replyTo,
    name: 'AiSED Conference Registration'
  };
}

function shouldAttachPdf(record) {
  return record.route === 'Call for Papers';
}

function getEmailSubject(record) {
  if (record.route === 'Call for Papers') {
    return `${AISED.conferenceName} paper registration received - ${record.reference}`;
  }
  if (record.route === 'Participants') {
    return `${AISED.conferenceName} participant registration received - ${record.reference}`;
  }
  if (record.route === 'Invited Guests') {
    return `${AISED.conferenceName} invited guest registration received - ${record.reference}`;
  }
  if (record.route === 'Partners') {
    return `${AISED.conferenceName} partnership registration received - ${record.reference}`;
  }
  return `${AISED.conferenceName} registration received - ${record.reference}`;
}

function getEmailBody(record) {
  const greeting = `Dear ${getRecipientName(record)},`;
  const acknowledgement = getRegistrationAcknowledgement();
  const closing = [
    '',
    'Regards,',
    'AiSED Conference Secretariat'
  ].join('\n');

  if (record.route === 'Call for Papers') {
    return [
      greeting,
      '',
      `Thank you for registering for ${AISED.conferenceName} under Call for Papers.`,
      acknowledgement,
      '',
      `Reference: ${record.reference}`,
      `Category: ${record.subsection || '-'}`,
      `Type: ${record.type || '-'}`,
      `Paper title: ${record.paperTitle || '-'}`,
      `Submit to SCOPUS: ${record.submitToScopus || '-'}`,
      `SCOPUS presentation mode: ${record.scopusPresentationMode || '-'}`,
      `Estimated payable amount: ${record.estimatedPayableAmount ? `RM${record.estimatedPayableAmount}` : '-'}`,
      '',
      'We have received your paper registration and submission details. Your paper will be reviewed by the committee, and we will inform you by 29th August 2026 for the next step.',
      '',
      'Please find the attached acknowledgement letter for your records.',
      closing
    ].join('\n');
  }

  if (record.route === 'Participants') {
    const details = getParticipantEmailDetails(record);
    return [
      greeting,
      '',
      `Thank you for registering for ${AISED.conferenceName}.`,
      acknowledgement,
      '',
      'Registration details:',
      ...details,
      '',
      'Note: You shall receive the confirmation email or further engagement / next step personally from the secretariat soon.',
      closing
    ].join('\n');
  }

  if (record.route === 'Invited Guests') {
    return [
      greeting,
      '',
      `Thank you for completing your invited guest registration for ${AISED.conferenceName}.`,
      acknowledgement,
      '',
      `Reference: ${record.reference}`,
      `Guest role: ${record.guestType || record.type || '-'}`,
      '',
      'The conference secretariat will be in touch if any further information is required.',
      closing
    ].join('\n');
  }

  if (record.route === 'Partners') {
    return [
      greeting,
      '',
      `Thank you for registering your organisation as part of ${AISED.conferenceName}.`,
      acknowledgement,
      '',
      `Reference: ${record.reference}`,
      `Partner category: ${record.partnerType || '-'}`,
      `Organisation: ${record.organisation || '-'}`,
      '',
      'We appreciate your interest in being part of the conference. The conference secretariat will follow up on the next steps.',
      closing
    ].join('\n');
  }

  return [
    greeting,
    '',
    `Thank you for registering for ${AISED.conferenceName}.`,
    acknowledgement,
    '',
    `Reference: ${record.reference}`,
    closing
  ].join('\n');
}

function getRegistrationAcknowledgement() {
  return [
    '',
    'Your registration has been well received. The Organizing Team will get back to you to confirm your enrollment and revert to you with the details.'
  ].join('\n');
}

function getRecipientName(record) {
  return [record.title, record.name].filter(Boolean).join(' ') || record.name || 'Participant';
}

function getParticipantEmailDetails(record) {
  const lines = [
    `Reference: ${record.reference}`,
    `Participant category: ${record.participantSector || record.type || '-'}`,
    `Title: ${record.title || '-'}`,
    `Full name: ${record.name || '-'}`,
    `Organisation / Company: ${record.organisation || '-'}`,
    `Position / Designation: ${record.position || '-'}`,
    `Email: ${record.email || '-'}`,
    `Contact number: ${record.phone || '-'}`
  ];

  if (record.participantSector === 'HRD Corp Claimable') {
    lines.push(
      `HRD Corp Employer Code: ${record.hrdEmployerId || '-'}`,
      `HRD Corp Claimable Courses (HRD CC): ${record.hrdClaimableCourse || '-'}`,
      `MyKad / IC Number / Passport Number: ${record.participantIdNumber || '-'}`,
      `Contact person: ${record.billingContact || '-'}`,
      `Contact person's position: ${record.contactPersonPosition || '-'}`,
      `Contact person's email address: ${record.billingEmail || '-'}`,
      `Contact person's phone number: ${record.billingPhone || '-'}`,
      `Company address: ${record.companyAddress || '-'}`
    );
  } else if (record.participantSector === 'Government Agencies') {
    lines.push(
      `Department / unit: ${record.department || '-'}`,
      `Administrative contact person: ${record.billingContact || '-'}`,
      `Administrative email: ${record.billingEmail || '-'}`,
      `Purchase order / reference no.: ${record.referenceNo || '-'}`,
      `Official notes: ${record.participantNotes || '-'}`
    );
  } else {
    lines.push(
      `Company registration no.: ${record.companyRegistration || '-'}`,
      `Billing contact person: ${record.billingContact || '-'}`,
      `Billing email: ${record.billingEmail || '-'}`,
      `Purchase order / reference no.: ${record.referenceNo || '-'}`,
      `Delegate notes: ${record.participantNotes || '-'}`
    );
  }

  return lines;
}

function getPdfTitle(record) {
  if (record.route === 'Call for Papers') return 'Paper Registration Acknowledgement';
  if (record.route === 'Participants') return 'Participant Registration Acknowledgement';
  return 'Registration Acknowledgement';
}

function getPdfMessage(record) {
  if (record.route === 'Call for Papers') {
    return 'Thank you for registering under Call for Papers. Your paper submission has been received and will be reviewed by the committee. We will inform you by 29th August 2026 for the next step.';
  }
  if (record.route === 'Participants') {
    return 'Thank you for your participant registration. The conference committee will review your details and get back to you to confirm your attendance.';
  }
  return 'Thank you for your registration. The conference secretariat has received your details.';
}


function formatPdfDate(date) {
  return Utilities.formatDate(date, Session.getScriptTimeZone(), 'd MMMM yyyy');
}

function buildNotes(record) {
  const notes = [];
  if (record.attendanceInterest) notes.push(`Attendance interest: ${record.attendanceInterest}`);
  if (record.hrdEmployerId) notes.push(`HRD Corp employer ID: ${record.hrdEmployerId}`);
  if (record.hrdClaimableCourse) notes.push(`HRD Corp Claimable Courses: ${record.hrdClaimableCourse}`);
  if (record.participantIdNumber) notes.push(`Participant ID/passport: ${record.participantIdNumber}`);
  if (record.contactPersonPosition) notes.push(`Contact person position: ${record.contactPersonPosition}`);
  if (record.billingEmail) notes.push(`Billing email: ${record.billingEmail}`);
  if (record.billingPhone) notes.push(`Billing phone: ${record.billingPhone}`);
  if (record.companyAddress) notes.push(`Company address: ${record.companyAddress}`);
  if (record.department) notes.push(`Department: ${record.department}`);
  if (record.referenceNo) notes.push(`Reference no.: ${record.referenceNo}`);
  if (record.participantNotes) notes.push(`Participant notes: ${record.participantNotes}`);
  if (record.invitationNote) notes.push(`Invitation note: ${record.invitationNote}`);
  if (record.speakerBiography) notes.push(`Speaker biography: ${record.speakerBiography}`);
  if (record.partnershipInterest) notes.push(`Partnership interest: ${record.partnershipInterest}`);
  if (record.attachmentName) notes.push(`Attachments: ${record.attachmentName}`);
  return notes.join(' | ');
}

function folderUrl(folderId) {
  return `https://drive.google.com/drive/folders/${folderId}`;
}

function makeReference() {
  return `REG-${Utilities.formatDate(new Date(), Session.getScriptTimeZone(), 'yyMMdd-HHmmss')}`;
}

function jsonResponse(data) {
  return ContentService
    .createTextOutput(JSON.stringify(data))
    .setMimeType(ContentService.MimeType.JSON);
}

function escapeHtml(value) {
  return String(value || '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#039;');
}
